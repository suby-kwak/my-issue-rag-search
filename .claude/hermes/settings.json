      {
        "name": "implementation",
        "model": "sonnet",
        "keywords": ["implement", "code", "write", "fix", "deploy", "test", "commit"]
      }
    ]
  },
  "timezone": "UTC+9",
  "heartbeat": {
    "enabled": true,
    "interval": 30,
    "prompt": "prompts/heartbeat.md"
  },
